EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_REVENUECAT_IOS=your-revenuecat-ios-key
EXPO_PUBLIC_REVENUECAT_ANDROID=your-revenuecat-android-key
EXPO_PUBLIC_POSTHOG_KEY=your-posthog-key
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Stripe (web payments) — publishable key only, secret key goes in Supabase Edge Function secrets
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
# Edge Function secrets (set via: supabase secrets set KEY=value)
# STRIPE_SECRET_KEY, STRIPE_PRICE_MONTHLY, STRIPE_PRICE_ANNUAL
# OPENAI_API_KEY (for food photo analysis — server-side only, never expose client-side)
# ALLOWED_ORIGINS (comma-separated, e.g. https://forga.fr,https://app.forga.fr)
